"""BUILD definitions for cuda_nvrtc package"""

# This BUILD file is used within the arch specific cuda redist repository.
#
# Any user-facing target should be listed in _REPO_PUBLIC_TARGETS so that the
# @cuda_nvrtc proxy repository can re-export it.

load("@rules_cc//cc:cc_library.bzl", "cc_library")
load("@rules_cc//cc:cc_import.bzl", "cc_import")
load("//:version.bzl", "LIB_VERSIONS")

cc_import(
    name = "nvrtc_main",
    deps = [":headers"],
    shared_library = "lib/libnvrtc.so." + LIB_VERSIONS["libnvrtc"],
    visibility = ["//visibility:public"],
)

cc_import(
    name = "nvrtc_builtins",
    static_library = "lib/libnvrtc-builtins_static.a",
    deps = [":headers"],
    shared_library = "lib/libnvrtc-builtins.so." + LIB_VERSIONS["libnvrtc-builtins"],
    visibility = ["//visibility:public"],
)
cc_import(
    name = "nvrtc",
    static_library = "lib/libnvrtc_static.a",
    shared_library = "lib/libnvrtc.so." + LIB_VERSIONS["libnvrtc"],
    deps = [":nvrtc_builtins", ":headers"],
    visibility = ["//visibility:public"],
)

cc_import(
    name = "nvrtc_static",
    deps = [":headers"],
    static_library = "lib/libnvrtc_static.a",
    visibility = ["//visibility:public"],
)

cc_import(
    name = "nvrtc_builtins_static",
    deps = [":headers"],
    static_library = "lib/libnvrtc-builtins_static.a",
    visibility = ["//visibility:public"],
)

cc_import(
    name = "nvrtc_stub",
    interface_library = "lib/stubs/libnvrtc.so",
    system_provided = 1,
    visibility = ["//visibility:public"],
)

filegroup(
    name = "shared_library_files",
    srcs = [
        "lib/libnvrtc.so." + LIB_VERSIONS["libnvrtc"],
        "lib/libnvrtc-builtins.so." + LIB_VERSIONS["libnvrtc-builtins"],
    ],
    visibility = ["//visibility:public"],
)

filegroup(
    name = "header_list",
    srcs = [
        "include/nvrtc.h",
    ],
    visibility = ["//visibility:public"],
)


cc_library(
    name = "headers",
    hdrs = [":header_list"],
    includes = ["include"],
    strip_include_prefix = "include",
    visibility = ["//visibility:public"],
)
