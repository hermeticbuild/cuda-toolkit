cc_binary(
    name = "nvml_query_smoke",
    srcs = ["nvml_query_smoke.cc"],
    deps = [
        ":smoke_test_common",
        "@cuda//nvml:nvml",
    ],
)

cc_binary(
    name = "nvtx_range_smoke",
    srcs = ["nvtx_range_smoke.cc"],
    linkopts = ["-ldl"],
    deps = [
        ":smoke_test_common",
        "@cuda//nvtx:headers",
    ],
)

cc_binary(
    name = "cupti_activity_smoke",
    srcs = ["cupti_activity_smoke.cc"],
    deps = [
        ":smoke_test_common",
        "@cuda//cupti:cupti",
        ":cuda_headers",
    ],
)
