    srcs = ["cusparse_spmv_smoke.cc"],
    deps = [
        ":smoke_test_common",
        "@cuda//cusparse:cusparse",
        ":cuda_headers",
    ],
)

cc_binary(
    name = "cusolver_cholesky_smoke",
    srcs = ["cusolver_cholesky_smoke.cc"],
    deps = [
        ":smoke_test_common",
        "@cuda//cusolver:cusolver",
        ":cuda_headers",
    ],
)

cc_binary(
    name = "cudnn_conv_descriptor_smoke",
    srcs = ["cudnn_conv_descriptor_smoke.cc"],
    deps = [
        ":smoke_test_common",
        "@cuda//cudnn:cudnn",
        ":cuda_headers",
    ],
